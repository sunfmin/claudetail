#!/usr/bin/env python3
"""
watchtail - Watch/tail Claude Code JSONL session logs in human-readable format.

Usage:
  watchtail [OPTIONS] [DIRECTORY]

Options:
  -n NUM        Number of recent messages to show (default: all)
  -f            Follow mode - keep watching for new content
  -p GLOB       Only watch files matching glob pattern (default: *.jsonl)
  -s SESSION    Only show a specific session (substring match on filename)
  --no-color    Disable colors
  --compact     Compact mode - truncate long content (like original behavior)
  -h, --help    Show help

If run without a directory and no JSONL files are found locally,
watchtail will list available Claude Code projects and let you pick one.

Examples:
  watchtail                        # auto-detect or pick a project
  watchtail -f                     # follow for new messages
  watchtail -n 20                  # last 20 messages
  watchtail -s 14fe559d            # specific session
  watchtail ~/.claude/projects/... # specific project directory
"""

import json
import sys
import os
import glob
import time
import argparse
from datetime import datetime

CLAUDE_PROJECTS_DIR = os.path.expanduser("~/.claude/projects")

# ANSI colors
class C:
    RESET   = "\033[0m"
    BOLD    = "\033[1m"
    DIM     = "\033[2m"
    USER    = "\033[1;36m"    # bold cyan
    ASST    = "\033[1;32m"    # bold green
    TOOL    = "\033[0;33m"    # yellow
    RESULT  = "\033[0;35m"    # magenta
    SYSTEM  = "\033[0;90m"    # gray
    THINK   = "\033[2;37m"    # dim white
    ERR     = "\033[1;31m"    # bold red
    FILE    = "\033[0;34m"    # blue
    TIME    = "\033[0;90m"    # gray
    SEP     = "\033[0;90m"    # gray
    META    = "\033[0;33m"    # yellow
    MODEL   = "\033[0;96m"    # light cyan
    HOOK    = "\033[0;93m"    # light yellow
    PROG    = "\033[0;90m"    # gray
    NUM     = "\033[0;97m"    # bright white

NO_COLOR = False
COMPACT = False

def c(color, text):
    if NO_COLOR:
        return text
    return f"{color}{text}{C.RESET}"

def format_time(ts_str):
    if not ts_str:
        return ""
    try:
        dt = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
        return dt.strftime("%H:%M:%S")
    except:
        return ts_str[:19]

def truncate(s, maxlen=200):
    if COMPACT and len(s) > maxlen:
        return s[:maxlen] + "..."
    return s

def indent_text(text, prefix="     "):
    """Indent all lines of text with a prefix."""
    return "\n".join(prefix + line for line in text.split("\n"))

def format_tool_input(inp):
    """Format tool_use input for human display - show all fields."""
    if not isinstance(inp, dict):
        return str(inp)
    parts = []
    for k, v in inp.items():
        val = str(v)
        if COMPACT and len(val) > 120:
            val = val[:120] + "..."
        parts.append(f"     {k}: {val}")
    return "\n".join(parts)

def format_usage(usage):
    """Format token usage info."""
    if not usage:
        return ""
    parts = []
    inp = usage.get("input_tokens", 0)
    out = usage.get("output_tokens", 0)
    cache_create = usage.get("cache_creation_input_tokens", 0)
    cache_read = usage.get("cache_read_input_tokens", 0)
    parts.append(f"in={inp}")
    parts.append(f"out={out}")
    if cache_create:
        parts.append(f"cache_write={cache_create}")
    if cache_read:
        parts.append(f"cache_read={cache_read}")
    tier = usage.get("service_tier", "")
    if tier:
        parts.append(f"tier={tier}")
    return " ".join(parts)

def render_content_block(block, role):
    """Render a single content block to human-readable lines."""
    lines = []
    if isinstance(block, str):
        if block.strip():
            lines.append(block.strip())
        return lines

    btype = block.get("type", "")

    if btype == "text":
        text = block.get("text", "")
        if text.strip():
            lines.append(text.strip())

    elif btype == "thinking":
        thinking = block.get("thinking", "")
        if thinking.strip():
            text = truncate(thinking.strip(), 300)
            lines.append(c(C.THINK, f"[thinking] {text}"))

    elif btype == "tool_use":
        name = block.get("name", "?")
        tool_id = block.get("id", "")
        inp = block.get("input", {})
        lines.append(c(C.TOOL, f"  ── tool: {name}") + (c(C.DIM, f"  ({tool_id[:12]})") if tool_id else ""))
        # Show all input parameters
        if inp:
            lines.append(c(C.TOOL, format_tool_input(inp)))

    elif btype == "tool_result":
        content = block.get("content", "")
        tool_use_id = block.get("tool_use_id", "")
        is_error = block.get("is_error", False)
        err_tag = c(C.ERR, " [ERROR]") if is_error else ""
        if isinstance(content, list):
            for item in content:
                if isinstance(item, dict) and item.get("type") == "text":
                    text = item.get("text", "")
                    preview = truncate(text.strip(), 300)
                    if preview:
                        lines.append(c(C.RESULT, f"  ── result{err_tag}: ") + preview)
                elif isinstance(item, dict) and item.get("type") == "image":
                    lines.append(c(C.RESULT, f"  ── result: [image]"))
        elif isinstance(content, str) and content.strip():
            preview = truncate(content.strip(), 300)
            lines.append(c(C.RESULT, f"  ── result{err_tag}: ") + preview)

    return lines

def render_record(record):
    """Render a JSONL record to human-readable output."""
    rtype = record.get("type", "")
    ts = format_time(record.get("timestamp", ""))
    lines = []

    if rtype == "user":
        msg = record.get("message", {})
        content = msg.get("content", "")
        is_meta = record.get("isMeta", False)
        permission_mode = record.get("permissionMode", "")
        cwd = record.get("cwd", "")
        version = record.get("version", "")
        git_branch = record.get("gitBranch", "")
        slug = record.get("slug", "")

        # Check if content is a list with tool_result blocks
        has_tool_result = False
        if isinstance(content, list):
            has_tool_result = any(
                isinstance(b, dict) and b.get("type") == "tool_result"
                for b in content
            )

        if has_tool_result:
            # Tool result response from user
            for block in content:
                if isinstance(block, dict):
                    lines.extend(render_content_block(block, "user"))
        elif is_meta:
            # Meta/system user message - show metadata
            meta_parts = []
            if version:
                meta_parts.append(f"v{version}")
            if cwd:
                meta_parts.append(f"cwd={cwd}")
            if git_branch:
                meta_parts.append(f"branch={git_branch}")
            if permission_mode:
                meta_parts.append(f"mode={permission_mode}")
            if slug:
                meta_parts.append(f"slug={slug}")
            if meta_parts:
                lines.append(c(C.META, f"  ── session: {' | '.join(meta_parts)}"))
        else:
            # Regular user message
            if isinstance(content, str) and content.strip():
                lines.append("")
                lines.append(c(C.SEP, "─" * 60))
                header = f"{c(C.TIME, ts)}  {c(C.USER, '▶ USER')}"
                meta_bits = []
                if permission_mode:
                    meta_bits.append(f"mode={permission_mode}")
                if cwd:
                    meta_bits.append(f"cwd={cwd}")
                if meta_bits:
                    header += c(C.DIM, f"  ({' | '.join(meta_bits)})")
                lines.append(header)
                lines.append(content.strip())
            elif isinstance(content, list):
                has_text = any(
                    (isinstance(b, dict) and b.get("type") == "text" and b.get("text", "").strip())
                    or (isinstance(b, str) and b.strip())
                    for b in content
                )
                if has_text:
                    lines.append("")
                    lines.append(c(C.SEP, "─" * 60))
                    lines.append(f"{c(C.TIME, ts)}  {c(C.USER, '▶ USER')}")
                for block in content:
                    lines.extend(render_content_block(block, "user"))

    elif rtype == "assistant":
        msg = record.get("message", {})
        content = msg.get("content", "")
        model = msg.get("model", "")
        stop_reason = msg.get("stop_reason", "")
        usage = msg.get("usage", {})

        if isinstance(content, list):
            has_visible = any(
                isinstance(b, dict) and (
                    (b.get("type") == "text" and b.get("text", "").strip()) or
                    b.get("type") == "tool_use" or
                    b.get("type") == "thinking"
                )
                for b in content
            )
            if has_visible:
                lines.append("")
                header = f"{c(C.TIME, ts)}  {c(C.ASST, '◀ ASSISTANT')}"
                meta_bits = []
                if model:
                    meta_bits.append(c(C.MODEL, model))
                if stop_reason:
                    meta_bits.append(f"stop={stop_reason}")
                usage_str = format_usage(usage)
                if usage_str:
                    meta_bits.append(usage_str)
                if meta_bits:
                    header += c(C.DIM, f"  ({' | '.join(meta_bits)})")
                lines.append(header)
            for block in content:
                rendered = render_content_block(block, "assistant")
                lines.extend(rendered)
        elif isinstance(content, str) and content.strip():
            lines.append("")
            header = f"{c(C.TIME, ts)}  {c(C.ASST, '◀ ASSISTANT')}"
            if model:
                header += c(C.DIM, f"  ({c(C.MODEL, model)})")
            lines.append(header)
            lines.append(content.strip())

    elif rtype == "system":
        subtype = record.get("subtype", "")
        if subtype == "turn_duration":
            dur = record.get("durationMs", 0)
            slug = record.get("slug", "")
            slug_info = f"  [{slug}]" if slug else ""
            lines.append(c(C.SYSTEM, f"  ── turn completed: {dur/1000:.1f}s{slug_info}"))
        elif subtype == "stop_hook_summary":
            hook_count = record.get("hookCount", 0)
            hook_infos = record.get("hookInfos", [])
            hook_errors = record.get("hookErrors", [])
            prevented = record.get("preventedContinuation", False)
            stop_reason = record.get("stopReason", "")
            has_output = record.get("hasOutput", False)
            parts = [f"hooks={hook_count}"]
            for hi in hook_infos:
                cmd = hi.get("command", "")
                dur_ms = hi.get("durationMs", 0)
                parts.append(f"{cmd} ({dur_ms}ms)")
            if hook_errors:
                parts.append(f"errors={hook_errors}")
            if prevented:
                parts.append("PREVENTED_CONTINUATION")
            if stop_reason:
                parts.append(f"reason={stop_reason}")
            lines.append(c(C.HOOK, f"  ── hook: {' | '.join(parts)}"))
        else:
            # Unknown system subtype - show it
            lines.append(c(C.SYSTEM, f"  ── system:{subtype} {json.dumps({k:v for k,v in record.items() if k not in ('type','subtype','parentUuid','isSidechain','uuid','timestamp','userType','entrypoint','cwd','sessionId','version','gitBranch','isMeta')}, default=str)[:200]}"))

    elif rtype == "progress":
        data = record.get("data", {})
        prog_type = data.get("type", "")
        if prog_type == "hook_progress":
            hook_event = data.get("hookEvent", "")
            hook_name = data.get("hookName", "")
            command = data.get("command", "")
            lines.append(c(C.PROG, f"  ── progress: hook {hook_event}/{hook_name} → {command}"))
        else:
            lines.append(c(C.PROG, f"  ── progress: {prog_type} {json.dumps(data, default=str)[:150]}"))

    elif rtype == "queue-operation":
        op = record.get("operation", "")
        content = record.get("content", "")
        lines.append(c(C.SYSTEM, f"  ── queue:{op} {content}"))

    elif rtype == "last-prompt":
        last = record.get("lastPrompt", "")
        if last:
            preview = truncate(str(last), 200)
            lines.append(c(C.DIM, f"  ── last-prompt: {preview}"))

    elif rtype == "file-history-snapshot":
        msg_id = record.get("messageId", "")
        is_update = record.get("isSnapshotUpdate", False)
        lines.append(c(C.DIM, f"  ── file-snapshot: msg={msg_id[:12]} update={is_update}"))

    else:
        # Unknown type - show raw
        lines.append(c(C.DIM, f"  ── {rtype}: {json.dumps(record, default=str)[:200]}"))

    return lines

def process_file(filepath, max_messages=None):
    """Read a JSONL file and return rendered lines."""
    records = []
    with open(filepath, "r") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                records.append(json.loads(line))
            except json.JSONDecodeError:
                continue

    if max_messages:
        # Filter to only user/assistant messages for counting
        msg_records = [r for r in records if r.get("type") in ("user", "assistant")]
        other_records = [r for r in records if r.get("type") not in ("user", "assistant")]
        if len(msg_records) > max_messages:
            # Find the timestamp of the cutoff
            cutoff_ts = msg_records[-max_messages].get("timestamp", "")
            msg_records = msg_records[-max_messages:]
            # Include non-message records within the time range
            if cutoff_ts:
                other_records = [r for r in other_records if r.get("timestamp", "") >= cutoff_ts]
            records = sorted(msg_records + other_records, key=lambda r: r.get("timestamp", ""))
        else:
            records = sorted(records, key=lambda r: r.get("timestamp", ""))

    all_lines = []
    for record in records:
        all_lines.extend(render_record(record))
    return all_lines

def get_project_display_name(dirname):
    """Convert Claude project directory name to a readable path."""
    # Format: -Users-sunfmin-Developments-projectname
    # Convert back to: /Users/sunfmin/Developments/projectname
    path = dirname.replace("-", "/", 1)  # first dash is leading /
    # Handle remaining dashes that are path separators vs dashes in names
    # Claude uses -- for actual dashes in names, - for path separators
    path = path.replace("--", "\x00")  # preserve actual double-dashes
    path = path.replace("-", "/")
    path = path.replace("\x00", "-")
    return path

def get_project_mtime(project_dir):
    """Get the most recent modification time of any JSONL file in a project."""
    pattern = os.path.join(project_dir, "*.jsonl")
    files = glob.glob(pattern)
    if not files:
        return 0
    return max(os.path.getmtime(f) for f in files)

def select_project():
    """Interactive project selector when not in a Claude project directory."""
    if not os.path.isdir(CLAUDE_PROJECTS_DIR):
        print("Error: No Claude Code projects found.", file=sys.stderr)
        print(f"Expected directory: {CLAUDE_PROJECTS_DIR}", file=sys.stderr)
        sys.exit(1)

    projects = []
    for entry in os.listdir(CLAUDE_PROJECTS_DIR):
        project_path = os.path.join(CLAUDE_PROJECTS_DIR, entry)
        if not os.path.isdir(project_path):
            continue
        # Check for JSONL files
        jsonl_files = glob.glob(os.path.join(project_path, "*.jsonl"))
        if not jsonl_files:
            continue
        mtime = get_project_mtime(project_path)
        display = get_project_display_name(entry)
        # Count sessions
        session_count = len(jsonl_files)
        # Total size
        total_size = sum(os.path.getsize(f) for f in jsonl_files)
        projects.append({
            "path": project_path,
            "dirname": entry,
            "display": display,
            "mtime": mtime,
            "session_count": session_count,
            "total_size": total_size,
        })

    if not projects:
        print("No Claude Code projects with session logs found.", file=sys.stderr)
        sys.exit(1)

    # Sort by most recently modified
    projects.sort(key=lambda p: p["mtime"], reverse=True)

    print(c(C.BOLD, "\n  Claude Code Projects\n"))
    print(c(C.DIM, f"  {'#':>3}  {'Last Active':<20}  {'Sessions':>8}  {'Size':>8}  Path"))
    print(c(C.DIM, f"  {'─'*3}  {'─'*20}  {'─'*8}  {'─'*8}  {'─'*40}"))

    for i, proj in enumerate(projects):
        num = f"{i+1:>3}"
        mtime_str = datetime.fromtimestamp(proj["mtime"]).strftime("%Y-%m-%d %H:%M")
        sessions = f"{proj['session_count']:>8}"
        size = format_size(proj["total_size"])
        path = proj["display"]
        print(f"  {c(C.NUM, num)}  {c(C.TIME, mtime_str):<20}  {c(C.ASST, sessions)}  {c(C.DIM, size):>8}  {c(C.FILE, path)}")

    print()
    try:
        choice = input(c(C.USER, "  Select project number (or q to quit): ")).strip()
    except (EOFError, KeyboardInterrupt):
        print()
        sys.exit(0)

    if choice.lower() in ("q", "quit", ""):
        sys.exit(0)

    try:
        idx = int(choice) - 1
        if 0 <= idx < len(projects):
            return projects[idx]["path"]
        else:
            print("Invalid selection.", file=sys.stderr)
            sys.exit(1)
    except ValueError:
        # Try substring match on display name
        matches = [p for p in projects if choice.lower() in p["display"].lower() or choice.lower() in p["dirname"].lower()]
        if len(matches) == 1:
            return matches[0]["path"]
        elif len(matches) > 1:
            print(f"Ambiguous match ({len(matches)} results). Be more specific.", file=sys.stderr)
            sys.exit(1)
        else:
            print("No matching project found.", file=sys.stderr)
            sys.exit(1)

def format_size(size_bytes):
    """Format bytes to human-readable size."""
    if size_bytes < 1024:
        return f"{size_bytes}B"
    elif size_bytes < 1024 * 1024:
        return f"{size_bytes/1024:.1f}K"
    elif size_bytes < 1024 * 1024 * 1024:
        return f"{size_bytes/(1024*1024):.1f}M"
    else:
        return f"{size_bytes/(1024*1024*1024):.1f}G"

def resolve_directory(args_directory):
    """Resolve the target directory, with interactive selection if needed."""
    directory = args_directory

    # If explicit directory given, use it
    if directory != ".":
        if os.path.isdir(directory):
            return directory
        # Try as a project name/substring under Claude projects
        if os.path.isdir(CLAUDE_PROJECTS_DIR):
            matches = []
            for entry in os.listdir(CLAUDE_PROJECTS_DIR):
                if directory.lower() in entry.lower() or directory.lower() in get_project_display_name(entry).lower():
                    full = os.path.join(CLAUDE_PROJECTS_DIR, entry)
                    if os.path.isdir(full):
                        matches.append(full)
            if len(matches) == 1:
                return matches[0]
            elif len(matches) > 1:
                print(f"Ambiguous project name '{directory}'. Matches:", file=sys.stderr)
                for m in matches:
                    print(f"  {get_project_display_name(os.path.basename(m))}", file=sys.stderr)
                sys.exit(1)
        print(f"Error: '{directory}' is not a directory", file=sys.stderr)
        sys.exit(1)

    # Default: current directory
    # Check if current dir has JSONL files
    if glob.glob(os.path.join(".", "*.jsonl")) or glob.glob(os.path.join(".", "**", "*.jsonl"), recursive=True):
        return "."

    # Check if we're inside a Claude project directory
    cwd = os.getcwd()
    if CLAUDE_PROJECTS_DIR in cwd:
        return "."

    # Check if there's a matching project for the current working directory
    cwd_project_name = cwd.replace("/", "-").lstrip("-")
    candidate = os.path.join(CLAUDE_PROJECTS_DIR, f"-{cwd_project_name}")
    if os.path.isdir(candidate) and glob.glob(os.path.join(candidate, "*.jsonl")):
        return candidate

    # No JSONL files found locally - offer project selection
    if sys.stdin.isatty():
        return select_project()
    else:
        print("No JSONL files found in current directory. Run interactively to select a project.", file=sys.stderr)
        sys.exit(1)

def main():
    parser = argparse.ArgumentParser(
        description="Watch/tail Claude Code JSONL logs in human-readable format",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
If run without arguments and no JSONL files are found locally,
watchtail will list available Claude Code projects to choose from.

You can also pass a project name substring as the directory argument:
  watchtail autotest5       # matches project containing 'autotest5'
"""
    )
    parser.add_argument("directory", nargs="?", default=".", help="Directory or project name to watch")
    parser.add_argument("-n", type=int, default=None, help="Number of recent messages to show")
    parser.add_argument("-f", action="store_true", help="Follow mode")
    parser.add_argument("-p", default="*.jsonl", help="File glob pattern (default: *.jsonl)")
    parser.add_argument("-s", default=None, help="Session filter (substring match)")
    parser.add_argument("--no-color", action="store_true", help="Disable colors")
    parser.add_argument("--compact", action="store_true", help="Compact mode - truncate long content")
    args = parser.parse_args()

    global NO_COLOR, COMPACT
    NO_COLOR = args.no_color or not sys.stdout.isatty()
    COMPACT = args.compact

    directory = resolve_directory(args.directory)

    pattern = os.path.join(directory, "**", args.p)
    files = sorted(glob.glob(pattern, recursive=True))

    if args.s:
        files = [f for f in files if args.s in os.path.basename(f)]

    if not files:
        print("No matching JSONL files found.", file=sys.stderr)
        sys.exit(1)

    # Print header
    print(c(C.BOLD, f"\n  watchtail — {directory}\n"))

    for filepath in files:
        session = os.path.basename(filepath).replace(".jsonl", "")
        fsize = format_size(os.path.getsize(filepath))
        print(c(C.FILE, f"━━━ Session: {session} ({fsize}) ━━━"))
        print(c(C.FILE, f"    {filepath}"))
        print()

        lines = process_file(filepath, max_messages=args.n)
        for line in lines:
            print(line)
        print()

    if not args.f:
        return

    # Follow mode
    print(c(C.SYSTEM, "\n── Following for new messages (Ctrl+C to stop) ──\n"))
    file_positions = {}
    for filepath in files:
        file_positions[filepath] = os.path.getsize(filepath)

    try:
        while True:
            # Also check for new files
            current_files = sorted(glob.glob(pattern, recursive=True))
            if args.s:
                current_files = [f for f in current_files if args.s in os.path.basename(f)]

            for filepath in current_files:
                prev_pos = file_positions.get(filepath, 0)
                try:
                    curr_size = os.path.getsize(filepath)
                except OSError:
                    continue

                if filepath not in file_positions:
                    # New file
                    session = os.path.basename(filepath).replace(".jsonl", "")
                    print(c(C.FILE, f"\n━━━ New session: {session} ━━━"))
                    file_positions[filepath] = 0
                    prev_pos = 0

                if curr_size > prev_pos:
                    with open(filepath, "r") as f:
                        f.seek(prev_pos)
                        new_data = f.read()
                    file_positions[filepath] = curr_size

                    for line in new_data.strip().split("\n"):
                        if not line.strip():
                            continue
                        try:
                            record = json.loads(line)
                            rendered = render_record(record)
                            for l in rendered:
                                print(l)
                        except json.JSONDecodeError:
                            continue
                    sys.stdout.flush()

            time.sleep(0.5)
    except KeyboardInterrupt:
        print(c(C.SYSTEM, "\n── Stopped ──"))

if __name__ == "__main__":
    main()
